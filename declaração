<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Declaração Oficial</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<style>
body {
  margin: 0;
  background: #2a5298;
  font-family: Arial;
}

#formBox {
  background: white;
  padding: 20px;
  max-width: 350px;
  margin: 30px auto;
  border-radius: 10px;
  text-align: center;
}

input {
  display: block;
  margin: 10px auto;
  padding: 12px;
  width: 95%;
  font-size: 16px;
}

button {
  padding: 12px;
  width: 100%;
  background: #1e3c72;
  color: white;
  border: none;
  font-size: 16px;
  border-radius: 5px;
  margin-top: 10px;
}

#documento {
  width: 794px;
  height: 1123px;
  background: white;
  margin: auto;
  padding: 70px 80px 70px 80px;
  font-family: "Times New Roman", serif;
  position: relative;
  box-sizing: border-box;
}

#documento::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 700px;
  height: 700px;
  background: url('fundo.png') no-repeat center;
  background-size: contain;
  opacity: 0.035;
  transform: translate(-50%, -50%);
}

.cabecalho {
  text-align: center;
  line-height: 1.4;
  font-size: 16px;
}

.brasao {
  width: 120px;
  display: block;
  margin: 0 auto 10px auto;
}

.titulo {
  text-align: center;
  font-weight: bold;
  margin-top: 60px;
  font-size: 22px;
  text-decoration: underline;
}

.texto {
  margin-top: 80px;
  text-align: justify;
  line-height: 2.2;
  font-size: 20px;
  text-indent: 60px;
}

.data {
  position: absolute;
  bottom: 220px;
  left: 80px;
  font-size: 14px;
}

.assinatura {
  position: absolute;
  bottom: 60px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
}

.assinatura img {
  width: 220px;
}

.carimbo {
  position: absolute;
  bottom: 40px;
  right: 60px;
}

.carimbo img {
  width: 90px;
  opacity: 0.85;
}

#btnPDF {
  max-width: 350px;
  margin: 20px auto;
  display: none;
}
</style>
</head>

<body>

<div id="formBox">
  <input type="text" id="nome" placeholder="Nome completo">
  <input type="text" id="ra" placeholder="RA">
  <input type="text" id="cpf" placeholder="CPF">
  <button id="btnGerar">Gerar Declaração</button>
</div>

<button id="btnPDF">📄 Baixar PDF</button>

<div id="documento" style="display:none;">

  <div class="cabecalho">
    <img src="brasao.png" class="brasao">

    <b>MINISTÉRIO DA DEFESA</b><br>
    <b>EXÉRCITO BRASILEIRO</b><br>
    11ª REGIÃO MILITAR<br>
    REGIÃO TENENTE-CORONEL LUIZ CRULS
  </div>

  <div class="titulo">DECLARAÇÃO DE COMPARECIMENTO</div>

  <div class="texto" id="texto"></div>
  <div class="data" id="data"></div>

  <div class="assinatura">
    <img src="assinatura.png">
  </div>

  <div class="carimbo">
    <img src="carimbo.png">
  </div>

</div>

<script>

// VALIDAR CPF
function validarCPF(cpf) {
  cpf = cpf.replace(/[^\d]+/g,'');

  if(cpf.length !== 11 || /^(\d)\1+$/.test(cpf)) return false;

  let soma = 0, resto;

  for (let i=1; i<=9; i++)
    soma += parseInt(cpf.substring(i-1, i)) * (11 - i);

  resto = (soma * 10) % 11;
  if ((resto === 10) || (resto === 11)) resto = 0;
  if (resto !== parseInt(cpf.substring(9, 10))) return false;

  soma = 0;
  for (let i=1; i<=10; i++)
    soma += parseInt(cpf.substring(i-1, i)) * (12 - i);

  resto = (soma * 10) % 11;
  if ((resto === 10) || (resto === 11)) resto = 0;

  return resto === parseInt(cpf.substring(10, 11));
}

// FORMATAR CPF
function formatarCPF(cpf) {
  cpf = cpf.replace(/\D/g, "");
  return cpf.replace(/(\d{3})(\d)/, "$1.$2")
            .replace(/(\d{3})(\d)/, "$1.$2")
            .replace(/(\d{3})(\d{1,2})$/, "$1-$2");
}

// DATA
function formatarData() {
  const dias = ["Domingo","Segunda-feira","Terça-feira","Quarta-feira","Quinta-feira","Sexta-feira","Sábado"];
  const meses = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];

  const hoje = new Date();

  return dias[hoje.getDay()] + ", " +
         hoje.getDate() + " de " +
         meses[hoje.getMonth()] + " de " +
         hoje.getFullYear();
}

// TURNO AUTOMÁTICO
function obterTurno() {
  const hora = new Date().getHours();
  return hora < 12 ? "MATUTINO" : "VESPERTINO";
}

// GERAR
document.getElementById("btnGerar").onclick = () => {
  const nome = document.getElementById("nome").value.trim().toUpperCase();
  const ra = document.getElementById("ra").value.trim();
  const cpf = document.getElementById("cpf").value.trim();

  if (!nome || !ra || !cpf) {
    alert("Preencha todos os campos!");
    return;
  }

  if (!validarCPF(cpf)) {
    alert("CPF inválido!");
    return;
  }

  const cpfFormatado = formatarCPF(cpf);
  const turno = obterTurno();

  document.getElementById("texto").innerHTML =
  "Declaro para os devidos fins de direito e a quem possa interessar, que o Sr <b>" +
  nome + "</b>&nbsp;&nbsp; RA: <b>" + ra + "</b>" +
  "&nbsp;&nbsp; CPF: <b>" + cpfFormatado + "</b>" +
  " compareceu nesta data no turno <b>" + turno + "</b> NA COMISSÃO DE SELEÇÃO PERMANENTE DAS FORÇAS ARMADAS DO DISTRITO FEDERAL (CSPFA/DF).";

  document.getElementById("data").innerText = formatarData() + ".";

  document.getElementById("formBox").style.display = "none";
  document.getElementById("documento").style.display = "block";
  document.getElementById("btnPDF").style.display = "block";
};

// PDF
document.getElementById("btnPDF").onclick = () => {
  const element = document.getElementById("documento");

  html2pdf().set({
    margin: 0,
    filename: 'declaracao.pdf',
    html2canvas: { scale: 3 },
    jsPDF: { unit: 'px', format: [794,1123] }
  }).from(element).save();
};

</script>

</body>
</html>
